# Copy to backend/.env and fill in your values
ENVIRONMENT=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=arrowverse
DB_USER=arrowverse
DB_PASSWORD=arrowverse

# Optional override (otherwise built from DB_* above):
# DATABASE_URL=mysql+aiomysql://arrowverse:arrowverse@localhost:3306/arrowverse

JWT_SECRET=dev-secret-change-me-before-production
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
CORS_ORIGINS=http://localhost:4200,http://localhost:8000
SPA_CLIENT_ID=arrowverse-web
EXTENSION_CLIENT_ID=arrowverse-extension

# Set to false to hide registration and reject POST /api/auth/register (invite-only prod)
PUBLIC_REGISTRATION=true
