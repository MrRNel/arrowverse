# Copy to `.env.production` on your server and replace secrets.
# For Docker / Coolify, set these as container environment variables instead.
ENVIRONMENT=production

DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_NAME=arrowverse
DB_USER=arrowverse
DB_PASSWORD=replace-with-strong-password

JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
CORS_ORIGINS=https://arrowverse.example.com
SPA_CLIENT_ID=arrowverse-web
EXTENSION_CLIENT_ID=arrowverse-extension

# false = invite-only; hides Register tab and returns 403 on POST /api/auth/register
PUBLIC_REGISTRATION=true
