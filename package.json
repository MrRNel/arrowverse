{
  "name": "arrowverse",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k -n api,web -c cyan,magenta \"npm:start:api\" \"npm:start:web\"",
    "start:web": "ng serve",
    "start:api": "node scripts/run-api.mjs",
    "start:prod": "npm run build && cross-env ENVIRONMENT=production node scripts/run-api-prod.mjs",
    "db:schema": "node scripts/print-db-schema.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate": "node scripts/migrate-db.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "setup:backend": "powershell -ExecutionPolicy Bypass -File scripts/setup-backend.ps1",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "sync:extension": "node scripts/sync-extension-data.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "prestart": "npm run icons:generate && npm run sync:extension",
    "prebuild": "npm run icons:generate && npm run sync:extension"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/localize": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^2.0.3",
    "bootstrap": "^5.3.8",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
